FROM python:3.11-slim

WORKDIR /app

# Install dependencies from both api and backend
COPY api/requirements.txt ./api/
COPY backend/requirements.txt ./backend/
RUN pip install --no-cache-dir -r api/requirements.txt -r backend/requirements.txt

# Copy source code
COPY api/ ./api/
COPY backend/ ./backend/
COPY testcases/ ./testcases/

WORKDIR /app/api

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]